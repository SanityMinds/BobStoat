SERVER_REPLY_BURST_LIMIT=6
GLOBAL_REPLY_BURST_WINDOW_SECONDS=60
GLOBAL_REPLY_BURST_LIMIT=20
MULTI_SERVER_REPLY_WINDOW_SECONDS=45

PING_BATCH_WINDOW_SECONDS=0
CONVERSATION_FOLLOWUP_WINDOW_SECONDS=10
REPLY_REVISION_WINDOW_SECONDS=5
DIRECT_MESSAGE_REPLY_DELAY_SECONDS=8
USER_TRIGGER_COOLDOWN_SECONDS=0
TYPING_BASE_DELAY_SECONDS=1.5
TYPING_CHARS_PER_SECOND=35
TYPING_MIN_DELAY_SECONDS=3
TYPING_MAX_DELAY_SECONDS=5
TYPING_FULL_LENGTH_CHARS=1600
TYPING_JITTER_SECONDS=0
TYPING_REFRESH_SECONDS=3
DUPLICATE_MESSAGE_COOLDOWN_SECONDS=300
DUPLICATE_MESSAGE_SIMILARITY=0.86
CHANNEL_ACTIVITY_WINDOW_SECONDS=60
CHANNEL_ACTIVITY_SILENCE_MIN_MESSAGES=8
CHANNEL_ACTIVITY_SILENCE_MAX_MESSAGES=8
CHANNEL_ACTIVITY_THRESHOLD_REFRESH_SECONDS=3600

HYBRID_RANDOM_IMAGE_CHANCE=0.05
HYBRID_RANDOM_TTS_CHANCE=0.05
AI_REACTION_CHANCE=0
AI_REACTION_CHECK_EVERY_MESSAGES=3
AI_REACTION_MAX_MESSAGE_CHARS=700
AI_REACTION_MAX_TOKENS=500
COMMAND_COOLDOWN_SECONDS=60
TTS_COMMAND_COOLDOWN_SECONDS=180
PERSONALITY_CHANGE_CHANNEL_COOLDOWN_SECONDS=60

BLOCKLIST_USER_IDS=
SERVER_BLACKLIST_IDS=
BYPASS_USER_IDS=

